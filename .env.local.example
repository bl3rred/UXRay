# Required: Browser Use Cloud API key.
BROWSER_USE_API_KEY=your-browser-use-key
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
UXRAY_FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Optional: Supabase auth for GitHub sign-in on the frontend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: backend-only Supabase Storage for durable screenshots/artifacts.
# Use your project's service role key here. Never expose it in the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uxray-artifacts
UXRAY_LOCAL_REPO_BUILD_ENABLED=true
UXRAY_LOCAL_REPO_BUILD_ROOT=C:\Users\rfarr\Desktop\uxray\apps\api\data\repo-builds
UXRAY_REPO_PREVIEW_TUNNEL_ENABLED=true
UXRAY_REPO_PREVIEW_TUNNEL_BINARY=cloudflared

# Optional: Browser Use Cloud model selector. This does not require your own Anthropic key.
BROWSER_USE_MODEL=claude-sonnet-4.6
BROWSER_USE_RUN_TIMEOUT_SECONDS=240

# Optional hosted Fetch.ai evaluation stage.
FETCH_EVALUATION_ENABLED=false
FETCH_EVALUATION_AGENT_URL=http://127.0.0.1:8100/evaluate
FETCH_EVALUATION_API_KEY=replace-with-plain-local-shared-secret
FETCH_EVALUATION_TIMEOUT_SECONDS=180
FETCH_RELAY_TIMEOUT_SECONDS=170
FETCH_RELAY_SYNC_SUBMIT_TIMEOUT_SECONDS=8
FETCH_RELAY_POLL_INTERVAL_SECONDS=1
AGENTVERSE_API_KEY=
FETCH_RELAY_AGENT_ADDRESS=
FETCH_RELAY_AGENT_SEED=
FETCH_RELAY_ORCHESTRATOR_ADDRESS=
ASI_ONE_API_KEY=

# Optional Gemini source review for supported repo-backed runs.
SOURCE_REVIEW_ENABLED=false
GEMINI_API_KEY=
SOURCE_REVIEW_MODEL=gemini-3.1-flash-lite-preview
SOURCE_REVIEW_TIMEOUT_SECONDS=45
SOURCE_REVIEW_QUEUE_RETRY_ATTEMPTS=1
SOURCE_REVIEW_RETRY_DELAY_SECONDS=30
