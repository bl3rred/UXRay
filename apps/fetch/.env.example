# Hosted Fetch.ai orchestrator settings for Agentverse Hosted Agents.
# Hosted agents ignore repo .env files at runtime; configure these as Agentverse secrets.
# Keep this file as the source of truth for what secrets to create online.

# Shared secret between the UXRay backend and the hosted orchestrator.
UXRAY_FETCH_SHARED_SECRET=replace-with-local-shared-secret

# ASI:One configuration used only for rephrasing and follow-up explanations.
ASI_ONE_API_KEY=replace-with-asi-one-api-key
UXRAY_FETCH_ASI_REPHRASE_ENABLED=true
UXRAY_FETCH_ASI_MODEL=asi1-mini

# Local relay settings. These should live in the root .env.local when you run the relay.
FETCH_EVALUATION_AGENT_URL=http://127.0.0.1:8100/evaluate
FETCH_EVALUATION_API_KEY=replace-with-local-shared-secret
AGENTVERSE_API_KEY=
FETCH_RELAY_AGENT_ADDRESS=
FETCH_RELAY_ORCHESTRATOR_ADDRESS=

# Public orchestrator metadata.
UXRAY_FETCH_ORCHESTRATOR_NAME=uxray_orchestrator_agent

# Hosted specialist agent addresses or IDs.
UXRAY_FETCH_FIRST_TIME_VISITOR_AGENT_ADDRESS=
UXRAY_FETCH_INTENT_DRIVEN_AGENT_ADDRESS=
UXRAY_FETCH_TRUST_EVALUATOR_AGENT_ADDRESS=
UXRAY_FETCH_CUSTOM_AUDIENCE_AGENT_ADDRESS=
UXRAY_FETCH_BOSS_AGENT_ADDRESS=
UXRAY_FETCH_SYNTHESIS_AGENT_ADDRESS=

# Orchestrator wait time for hosted specialist replies.
UXRAY_FETCH_ORCHESTRATOR_TIMEOUT_SECONDS=20
